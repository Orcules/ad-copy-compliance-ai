# --- OpenAI (required) ---
# Your OpenAI API key. The app will not start without it.
OPENAI_API_KEY=your-openai-api-key

# Generation model (default: gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini

# Moderation model (default: omni-moderation-latest)
OPENAI_MODERATION_MODEL=omni-moderation-latest

# Use the Responses API path when set to 1 (default: 1)
OPENAI_USE_RESPONSES=1

# --- Google credentials (optional) ---
# The app loads a service account from `service_account.json` in the project root.
# This file is gitignored — provide your own and NEVER commit real credentials.
# If absent, Google Sheets and GCS are skipped and offline JSON fallbacks are used.
GOOGLE_SERVICE_ACCOUNT_FILE=service_account.json

# --- Google Cloud Storage (optional) ---
# Bucket and folder used for article context lookups.
# These are read in app.py — replace with your own values.
GCS_BUCKET_NAME=your-gcs-bucket
GCS_FOLDER_NAME=your-gcs-folder
